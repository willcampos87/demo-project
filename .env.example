# Copy this file to `.env` and fill in values. Never commit `.env`.
#
# YouTube Data API v3 — create an API key in Google Cloud Console:
# APIs & Services → Credentials → Create credentials → API key
# Enable "YouTube Data API v3" for the same project.
# Security: restrict the key (HTTP referrers / IP / app restrictions) in GCP to limit abuse if leaked.
# If the key is exposed, rotate it in Credentials and update this file locally only (not in Git).
# If the repo lives in a cloud-synced folder (e.g. OneDrive), treat `.env` as sensitive in backups too.
YOUTUBE_API_KEY=

# Recipient for tools/send_gmail_report.py and complete_youtube_report.py (your Google account email).
# REPORT_TO_EMAIL=

# Modal cloud execution (tools/modal_pipeline.py)
# These are NOT used at runtime from .env — they belong in the Modal Secret
# named 'youtube-niche-secrets' at modal.com/secrets.
# YOUTUBE_API_KEY and REPORT_TO_EMAIL above are the same values.
# GOOGLE_TOKEN_JSON — paste the full contents of your local token.json here
#   (run tools/google_oauth_auth.py locally first, then copy token.json contents).
# GOOGLE_TOKEN_JSON=

# Example placeholders — extend as needed:
# DATABASE_URL=
